# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# Read by compose/docker-compose.yml and backup/backup.sh.

# --- MSSQL (compose) ---
# SA password for the dev MSSQL container. Must satisfy SQL Server's password
# policy (8+ chars, upper/lower/digit/symbol).
MSSQL_SA_PASSWORD=change_me

# --- Nginx Proxy Manager API (backup/restore) ---
# Admin credentials used to obtain a short-lived API token for exporting config.
# This is the email + password you set on NPM's first-run admin account.
NPM_API_IDENTITY=admin@example.com
NPM_API_SECRET=change_me

# Base URL of the NPM REST API. Default targets the admin port on localhost.
# NPM_API_URL=http://127.0.0.1:81/api
